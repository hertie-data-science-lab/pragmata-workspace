# config/workspace.env — operational tunables for the BSt pragmata-workspace pipeline.
#
# Read by BOTH the shell glue (scripts/lib/common.sh) and the Python glue
# (scripts/lib/workspace.py), using the same KEY=VALUE format and the same
# "existing environment wins" rule. 

# --- querygen: queries per spec ---
# baseline specs   (<domain>.yaml)
N_BASELINE=500
# edge-case specs  (<domain>_edgecase.yaml)
N_EDGECASE=60

# --- publikationsbot ---
# prod backend base URL
PUBLIKATIONSBOT_URL=https://publikationsbot-backend-prd.icygrass-f616b1f5.swedencentral.azurecontainerapps.io
# seconds to sleep after each network-touching query (throttle)
INTER_QUERY_DELAY_S=2.0
# overnight bot-phase concurrency (spec-level workers)
N_PARALLEL_BOTS=4

# --- disk guards (MB) ---
# abort below this much free space
DISK_MIN_FREE_MB=100
# warn (but continue) below this much
DISK_WARN_FREE_MB=500

# --- pragmata src: demo deployment ---
# all annotation data was imported by the demo-branch
# and the monitoring script reads it back through the same branch. 
# PRAGMATA_SRC shadows the installed pragmata on sys.path; unset to
# use the installed package.
PRAGMATA_SRC=/home/azureuser/pragmata-demo/src

# --- monitoring (scripts/monitor.py) ---
# Inter-completion gaps longer than this are treated as session breaks (pauses,
# e.g. overnight) and excluded from the median cadence — reported separately.
MONITOR_SESSION_GAP_MIN=30
# Don't report a median cadence below this many completed records (too noisy).
MONITOR_MIN_RECORDS_FOR_TIMING=5
# Bootstrap resamples for IAA confidence intervals. Lower than the CLI default
# (1000) — calibration sets are small and this runs daily.
MONITOR_IAA_RESAMPLES=200
