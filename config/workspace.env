# config/workspace.env — operational tunables for the BSt pragmata-workspace pipeline.
#
# Read by BOTH the shell glue (scripts/lib/common.sh) and the Python glue
# (scripts/lib/workspace.py), using the same KEY=VALUE format and the same
# "existing environment wins" rule. 

# --- querygen: queries per spec ---
# baseline specs   (<domain>.yaml)
N_BASELINE=500
# edge-case specs  (<domain>_edgecase.yaml)
N_EDGECASE=60

# --- publikationsbot ---
# prod backend base URL
PUBLIKATIONSBOT_URL=https://publikationsbot-backend-prd.icygrass-f616b1f5.swedencentral.azurecontainerapps.io
# seconds to sleep after each network-touching query (throttle)
INTER_QUERY_DELAY_S=2.0
# overnight bot-phase concurrency (spec-level workers)
N_PARALLEL_BOTS=4

# --- disk guards (MB) ---
# abort below this much free space
DISK_MIN_FREE_MB=100
# warn (but continue) below this much
DISK_WARN_FREE_MB=500
