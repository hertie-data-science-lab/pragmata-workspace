# Copy to .env and fill in. Loaded by scripts/lib (existing shell env wins).
# Secrets — never commit the real .env (it is gitignored).

# --- Argilla (annotation setup + import target) ---
ARGILLA_API_URL=https://your-argilla-instance.example.com
ARGILLA_API_KEY=

# --- Azure OpenAI (querygen) ---
# Note the asymmetric naming: AZURE_OPENAI_* take the AZURE_ prefix but
# OPENAI_API_VERSION does not. This is a LangChain quirk (see scripts/pragmata_azure.py).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-12-01-preview
