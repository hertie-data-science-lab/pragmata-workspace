# Copy to .env and fill in. .env is gitignored; this template is committed.
# Loaded by scripts/lib/common.sh for every pipeline stage.

# --- Argilla (annotation instance) ---
ARGILLA_API_URL=https://argilla.example.internal
ARGILLA_API_KEY=replace-me

# --- LLM (querygen) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# --- pragmata pipeline source checkout (provides the `pragmata` CLI) ---
PRAGMATA_SRC=/path/to/pragmata/src

# --- publikationsbot (retrieval/answer backend) ---
PUBLIKATIONSBOT_URL=https://publikationsbot.example.internal

# --- eval data transport (Azure Blob; used by scripts/eval/sync.sh) ---
# Shared drop-point between the CPU annotation box and the GPU eval box.
# The SAS is data-plane auth (no ARM rights needed) — keep the real token in
# .env only. Ask the storage owner for a token that outlives the eval work, or
# document its rotation, so long transfers don't break on expiry.
EVAL_BLOB_ACCOUNT=replace-me
EVAL_BLOB_CONTAINER=replace-me
EVAL_BLOB_SAS=replace-me
